# Local real TJ logs (~12 GiB inspection corpus — never commit)
/logs/

# Workspace-level (после Sprint 3.5: D:\1C-Optimyzer\ стал корнем репо).
# Локальные ресурсы рядом с кодом — не часть продукта, не публиковать.
/.claude/
# HTML-мокапы других продуктов Сергея (Agenter, GosLog, Konvey).
# К 1C-Optimyzer не относятся.
/Design_NonProduct/
# PDF методики ЦУП / "Корпоративный инструментальный пакет" — материалы из ИТС.
# Не публиковать в репо (copyright + большие файлы).
*.pdf
# Пустая папка-остаток от устаревшего дубликата (Sprint 3.5 hoist).
# Windows handle не отпускает; исчезнет после ребута. Не трогаем git.
/МоделированиеТЖ/

# Opensource research workspace (Sprint 6 prep) — клоны чужих репо,
# скачанные JAR/binary, тестовые артефакты. Не часть продукта.
# Отчёт — в docs/sales_sprint/OPENSOURCE_RESEARCH_REPORT.md.
/research/

# Sprint 6 bundled binaries — Eclipse Temurin JRE 21 + bsl-language-server JAR.
# Sprint 7 добавил PerformanceStudio CLI (planview.exe, ~96 МБ).
# Скачиваются скриптами scripts/setup-bsl-ls-binaries.ps1 и
# scripts/setup-planview-binary.ps1 перед `tauri build`.
/frontend/src-tauri/binaries/

# Sprint 7 — local toolchain не публикуется в репо.
# .NET 10 SDK ставится user-mode через dotnet-install.ps1 (~700 МБ).
/tools/dotnet-10/
# Built CLI artifact (промежуточный, копируется в frontend/src-tauri/binaries/planview/).
/tools/planview-built/
# Кешированный download для скрипта setup-planview-binary.ps1.
/tools/sprint7_discovery/PerformanceStudio-win-x64.zip

# Рабочие материалы Сергея рядом с кодом — не часть репозитория 1C-Optimyzer.
/ТЖ/
/data/
/.s12_ai_out/
*.err

# Одноразовые промпт-файлы и рабочие заметки в корне (задачи для Claude Code) —
# не публикуются, живут только локально.
/Оптимайзер_*.md
/Статья_*.md
/OPTIMYZER_*.md
find_pattern.ps1
fix_form_badge.ps1
patch_form_chip.ps1
unpatch_form_chip.ps1

# Готовые установщики (.msi) — собираются локально/CI, не публикуются в git
# (сотни МБ). Раздаются через GitHub Releases.
/dist-installer/
