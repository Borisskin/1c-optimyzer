# Боевые значения VITE_* для production-сборки фронтенда (Tauri desktop) и кабинета.
#
# Vite читает этот файл в режиме production (`vite build` / `npm run tauri build`)
# и он ПЕРЕКРЫВАЕТ одноимённые переменные из общего .env (там — localhost для dev).
# Благодаря этому релизный .msi ведёт кнопки «Личный кабинет»/«Перейти на Pro» и
# AI-запросы на боевые домены, а не на localhost dev-серверов.
#
# Файл не содержит секретов (только публичные URL) и коммитится в репозиторий.

VITE_API_BASE=https://api.optimyzer.pro
VITE_CLOUD_API_BASE=https://api.optimyzer.pro
VITE_CABINET_URL=https://account.optimyzer.pro
VITE_LANDING_URL=https://optimyzer.pro
