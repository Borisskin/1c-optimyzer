# =============================================================================
# Optimyzer Server — пример конфигурации
# Скопировать в `.env` (не коммитить!) и заполнить реальными значениями.
# =============================================================================

# --- General ---
ENV=development                              # development | staging | production
DEBUG=true
LOG_LEVEL=DEBUG                              # DEBUG | INFO | WARNING | ERROR
HOST=127.0.0.1
PORT=8001

# --- Database ---
# Локально удобнее SQLite (никаких сервисов), но в проде — PostgreSQL.
# Примеры:
#   sqlite+pysqlite:///./optimyzer.db
#   postgresql+psycopg2://user:pass@localhost:5432/optimyzer
DATABASE_URL=sqlite+pysqlite:///./optimyzer.db

# --- Auth / JWT ---
# Сгенерировать новый: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-random-64-chars-in-production-do-not-use-default
JWT_ACCESS_TTL_SECONDS=900                   # 15 минут
JWT_REFRESH_TTL_DAYS=30
JWT_DEVICE_TTL_DAYS=90                       # для desktop активаций (long-lived)
JWT_ALGORITHM=HS256

# --- Yandex OAuth ---
# Создать приложение: https://oauth.yandex.ru/client/new
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback
YANDEX_OAUTH_AUTHORIZE_URL=https://oauth.yandex.ru/authorize
YANDEX_OAUTH_TOKEN_URL=https://oauth.yandex.ru/token
YANDEX_USER_INFO_URL=https://login.yandex.ru/info

# --- YooKassa ---
# Создать магазин: https://yookassa.ru/my/funds
# Для разработки — sandbox credentials.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=                     # для signature verification, если YooKassa включит
YOOKASSA_RETURN_URL=http://127.0.0.1:5173/credits?status=pending

# --- CORS ---
# Через запятую. В dev — locked на vite dev server.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Email (transactional, опционально для dev) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Optimyzer <hello@optimyzer.pro>

# --- Anthropic (используется самим desktop, не сервером — справка для полноты) ---
# ANTHROPIC_API_KEY=

# --- Rate limiting ---
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_ANONYMOUS=20/minute

# --- Admin ---
# Для GET /v1/admin/* — Basic auth, только для Сергея.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# --- Cookies ---
# В проде включи Secure + SameSite=Lax. В dev по http — Secure отключаем.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# --- Soft caps ---
FREE_AI_MONTHLY_LIMIT=5
PRO_AI_MONTHLY_SOFT_CAP=1000
DEVICE_LIMIT_FREE=1
DEVICE_LIMIT_PRO=5
