# =============================================================================
# Optimyzer — единая конфигурация (root .env)
# =============================================================================
# Используется ВСЕМИ компонентами проекта:
#   • backend/  — desktop Python backend (DuckDB + Claude AI)
#   • server/   — облачный FastAPI (auth, billing, cabinet API)
#   • cabinet/  — React webapp (vite читает VITE_*)
#   • frontend/ — Tauri desktop (vite читает VITE_* и TAURI_*)
#
# Скопировать → `.env` (gitignored). Заполнить реальными значениями.
# Что не используется в твоём dev-сетапе — можно оставить пустым.
# =============================================================================


# =============================================================================
# 1. DESKTOP BACKEND — Anthropic AI (для AI Explainer)
# =============================================================================
# Без ключа AI Explainer показывает «AI not configured».
# Получить: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=

# Опционально — переопределить модель. По умолчанию claude-sonnet-4-6
# (баланс качество/cost, ~$0.003 на request с 1024 max_tokens).
# ANTHROPIC_MODEL=claude-sonnet-4-6


# =============================================================================
# 2. CLOUD SERVER (server/) — FastAPI backend
# =============================================================================

# --- General ---
ENV=development                              # development | staging | production
DEBUG=true
LOG_LEVEL=DEBUG
HOST=127.0.0.1
PORT=8001

# --- Database ---
# SQLite для dev (никаких сервисов), PostgreSQL для прода.
# Примеры:
#   sqlite+pysqlite:///./server/optimyzer.db
#   postgresql+psycopg2://user:pass@localhost:5432/optimyzer
DATABASE_URL=sqlite+pysqlite:///./server/optimyzer.db

# --- JWT ---
# Сгенерить: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-random-64-chars-in-production-do-not-use-default-please
JWT_ACCESS_TTL_SECONDS=900                   # 15 минут
JWT_REFRESH_TTL_DAYS=30
JWT_DEVICE_TTL_DAYS=90                       # для desktop активаций
JWT_ALGORITHM=HS256

# --- Yandex OAuth ---
# Зарегистрировать: https://oauth.yandex.ru/client/new
# Redirect URI должен СОВПАДАТЬ с тем что зарегистрирован в Yandex (иначе invalid_grant).
# Дев: http://localhost:8001/success — наш FastAPI ловит callback напрямую
# (без Apache/nginx proxy — так проще локалке).
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8001/success
YANDEX_OAUTH_AUTHORIZE_URL=https://oauth.yandex.ru/authorize
YANDEX_OAUTH_TOKEN_URL=https://oauth.yandex.ru/token
YANDEX_USER_INFO_URL=https://login.yandex.ru/info

# --- YooKassa ---
# Зарегистрировать: https://yookassa.ru/my/funds (привязать счёт самозанятого)
# Для dev — sandbox credentials. Если пусто — server работает в stub-mode
# (fake confirmation_url, чтобы фронт мог тестироваться без живой YooKassa).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_RETURN_URL=http://127.0.0.1:5173/credits?status=pending

# --- CORS ---
# Через запятую, без trailing slash.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Email (transactional, опционально в dev) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Optimyzer <hello@optimyzer.pro>

# --- Rate limiting (slowapi) ---
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_ANONYMOUS=20/minute

# --- Admin (HTTP Basic для /v1/admin/*) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# --- Cookies ---
# В проде Secure=true. В dev по http — false.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# --- Soft caps ---
FREE_AI_MONTHLY_LIMIT=5
PRO_AI_MONTHLY_SOFT_CAP=1000
DEVICE_LIMIT_FREE=1
DEVICE_LIMIT_PRO=5


# =============================================================================
# 3. WEB CABINET (cabinet/) — Vite читает VITE_* переменные
# =============================================================================

# Адрес backend API. В dev — наш локальный server на :8001.
VITE_API_BASE=http://127.0.0.1:8001


# =============================================================================
# 4. DESKTOP FRONTEND (frontend/) — Tauri + Vite
# =============================================================================

# Адрес cloud API для license activation / heartbeat / usage / telemetry.
# Если пусто — desktop работает в local-only режиме (без cloud, без soft caps).
VITE_CLOUD_API_BASE=http://127.0.0.1:8001

# Адрес web-кабинета (для ссылок «Открыть личный кабинет» в desktop).
VITE_CABINET_URL=http://127.0.0.1:5173

# Адрес лендинга (для ссылок «Перейти на Pro» / «Купить кредиты»).
# Локально — статика через `python -m http.server 8000` в landing/ (см. QUICKSTART §5).
# При деплое поменять на https://optimyzer.pro.
VITE_LANDING_URL=http://localhost:8000
