// Общий модуль расширения ТЖМоделированиеРасш.
// Экспортные методы для запуска во ФоновыхЗаданиях из внешней обработки МоделированиеТЖ.
//
// Идея: внешняя обработка не может запустить свой метод во ФоновыеЗадания
// (платформа требует общий модуль конфигурации). Поэтому в расширении создан
// этот общий модуль с экспортными методами-воркерами. Обработка вызывает:
//
//   ФоновыеЗадания.Выполнить("ВоркерыТЖ.БлокировкаHolder", Массив(ИмяРегистра, ВремяСек))
//
// Каждый воркер делает свою блокировку в отдельной транзакции и откатывает —
// в базе ничего не сохраняется, только пишутся события TLOCK/TDEADLOCK/DBMSSQL в ТЖ.

#Область ПрограммныйИнтерфейс

// TLOCK Holder — берёт исключительную блокировку и держит ВремяСек.
// Параметры передаются как массив из ФоновыеЗадания.Выполнить.
Процедура БлокировкаHolder(Параметры) Экспорт

	ИмяРегистра = Параметры[0];
	ВремяСек = Параметры[1];

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		ПриостановитьВыполнение(ВремяСек);

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		// Не пробрасываем — фоновое задание иначе попадёт в "Аварийно завершено"
		// и не даст следующим воркерам стартовать. Лог пишется в ТЖ через EXCP.
		ЗаписьЖурналаРегистрации("ТЖМоделирование.Holder",
			УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// TLOCK Waiter — пытается взять ту же блокировку. Ждёт пока Holder не отпустит.
// Если ожидание > 1 сек — платформа пишет TLOCK событие в ТЖ.
Процедура БлокировкаWaiter(Параметры) Экспорт

	ИмяРегистра = Параметры[0];

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		// Получили — сразу отпускаем
		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.Waiter",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Дедлок типа 1 — эскалация S → X в одной транзакции (ЦУП 2.12.3.2).
Процедура ДедлокЭскалация(Параметры) Экспорт

	ИмяРегистра = Параметры[0];
	ПаузаСек = Параметры[1];

	НачатьТранзакцию();
	Попытка
		Блок1 = Новый БлокировкаДанных;
		Эл1 = Блок1.Добавить(ИмяРегистра);
		Эл1.Режим = РежимБлокировкиДанных.Разделяемый;
		Блок1.Заблокировать();

		ПриостановитьВыполнение(ПаузаСек);

		// Эскалация — оба воркера здесь конкурируют, один получит deadlock
		Блок2 = Новый БлокировкаДанных;
		Эл2 = Блок2.Добавить(ИмяРегистра);
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блок2.Заблокировать();

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.Эскалация",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Дедлок типа 2 — захват ресурсов в разном порядке (ЦУП 2.12.3.3).
// Параметры: Параметры[0] = "Рег1,Рег2" — порядок захвата для этого воркера.
Процедура ДедлокРазныйПорядок(Параметры) Экспорт

	ПараРегистров = Параметры[0];
	ПаузаСек = Параметры[1];

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		ЗаписьЖурналаРегистрации("ТЖМоделирование.РазныйПорядок",
			УровеньЖурналаРегистрации.Ошибка, , ,
			"Ожидается пара регистров через запятую, получено: " + ПараРегистров);
		Возврат;
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		Блок1 = Новый БлокировкаДанных;
		Эл1 = Блок1.Добавить(СокрЛП(Регистры[0]));
		Эл1.Режим = РежимБлокировкиДанных.Исключительный;
		Блок1.Заблокировать();

		ПриостановитьВыполнение(ПаузаСек);

		Блок2 = Новый БлокировкаДанных;
		Эл2 = Блок2.Добавить(СокрЛП(Регистры[1]));
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блок2.Заблокировать();

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.РазныйПорядок",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Дедлок типа 3 — оба процесса хотят X на одном ресурсе после S другого.
// Параметры: Параметры[0] = "Основной,Вспомогательный".
Процедура ДедлокОдинРесурс(Параметры) Экспорт

	ПараРегистров = Параметры[0];
	ПаузаСек = Параметры[1];

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		ЗаписьЖурналаРегистрации("ТЖМоделирование.ОдинРесурс",
			УровеньЖурналаРегистрации.Ошибка, , ,
			"Ожидается пара регистров через запятую, получено: " + ПараРегистров);
		Возврат;
	КонецЕсли;

	ОсновнойРегистр = СокрЛП(Регистры[0]);
	ВспомогРегистр = СокрЛП(Регистры[1]);

	НачатьТранзакцию();
	Попытка
		БлокS = Новый БлокировкаДанных;
		ЭлS = БлокS.Добавить(ВспомогРегистр);
		ЭлS.Режим = РежимБлокировкиДанных.Разделяемый;
		БлокS.Заблокировать();

		ПриостановитьВыполнение(ПаузаСек);

		БлокX = Новый БлокировкаДанных;
		ЭлX = БлокX.Добавить(ОсновнойРегистр);
		ЭлX.Режим = РежимБлокировкиДанных.Исключительный;
		БлокX.Заблокировать();

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.ОдинРесурс",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Sprint 9 — Дедлок X-X: явные X-блокировки в обратном порядке.
// Параметры[0] = "Рег1,Рег2" — порядок захвата для этого воркера.
// У второго воркера параметр будет "Рег2,Рег1" — классический deadlock.
Процедура ДедлокXX(Параметры) Экспорт

	ПараРегистров = Параметры[0];
	ПаузаСек = Параметры[1];

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		ЗаписьЖурналаРегистрации("ТЖМоделирование.DeadlockXX",
			УровеньЖурналаРегистрации.Ошибка, , ,
			"Ожидается пара регистров через запятую, получено: " + ПараРегистров);
		Возврат;
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		Блок1 = Новый БлокировкаДанных;
		Эл1 = Блок1.Добавить(СокрЛП(Регистры[0]));
		Эл1.Режим = РежимБлокировкиДанных.Исключительный;
		Блок1.Заблокировать();

		ПриостановитьВыполнение(ПаузаСек);

		Блок2 = Новый БлокировкаДанных;
		Эл2 = Блок2.Добавить(СокрЛП(Регистры[1]));
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блок2.Заблокировать();

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.DeadlockXX",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Sprint 9 — Дедлок в цепочке (A->B->C->A).
// Каждый воркер берёт X на одном регистре, ждёт, пытается взять X на следующем.
// Параметры[0] = "РегОт,РегДо" — порядок захвата для этого звена цепочки.
Процедура ДедлокЦепочка(Параметры) Экспорт

	ПараРегистров = Параметры[0];
	ПаузаСек = Параметры[1];

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		ЗаписьЖурналаРегистрации("ТЖМоделирование.DeadlockChain",
			УровеньЖурналаРегистрации.Ошибка, , ,
			"Ожидается пара регистров через запятую, получено: " + ПараРегистров);
		Возврат;
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		БлокОт = Новый БлокировкаДанных;
		ЭлОт = БлокОт.Добавить(СокрЛП(Регистры[0]));
		ЭлОт.Режим = РежимБлокировкиДанных.Исключительный;
		БлокОт.Заблокировать();

		ПриостановитьВыполнение(ПаузаСек);

		БлокДо = Новый БлокировкаДанных;
		ЭлДо = БлокДо.Добавить(СокрЛП(Регистры[1]));
		ЭлДо.Режим = РежимБлокировкиДанных.Исключительный;
		БлокДо.Заблокировать();

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.DeadlockChain",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Sprint 9 — Длинная транзакция: держит X-блокировку ВремяСек секунд.
// Параметры[0] = имя регистра, Параметры[1] = время в секундах (>= 30).
Процедура ДлиннаяТранзакция(Параметры) Экспорт

	ИмяРегистра = Параметры[0];
	ВремяСек = Параметры[1];
	Если ВремяСек < 5 Тогда
		ВремяСек = 30;
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		ПриостановитьВыполнение(ВремяСек);

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("ТЖМоделирование.LongTxn",
			УровеньЖурналаРегистрации.Информация, , , ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Пауза в секундах. В контексте rphost фонового задания COM может быть недоступен,
// поэтому используем простой busy-loop. CPU расходуется, но для моделирующего
// сценария это приемлемо — паузы 3-15 секунд на тестовой базе.
Процедура ПриостановитьВыполнение(Секунд)

	Если Секунд <= 0 Тогда
		Возврат;
	КонецЕсли;

	Финиш = ТекущаяДатаСеанса() + Секунд;
	Пока ТекущаяДатаСеанса() < Финиш Цикл
		// busy wait — нужен паузу выдержать честно, без шансов её ускорить
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
