// Модуль объекта внешней обработки МоделированиеТЖ.
// Серверная часть. Воркер-методы вызываются как из основной сессии (через UI),
// так и в воркер-режиме (когда обработка запущена через 1cv8c.exe /Execute с параметром /C).
//
// ПРИНЦИП работы:
//   - Для TLOCK/TDEADLOCK нужны параллельные сессии — внешняя обработка не может вызвать
//     свой метод во ФоновыеЗадания (требует общий модуль конфигурации). Решение —
//     запуск параллельных процессов 1cv8c.exe с /Execute этого же файла и /C"<команда>".
//   - Воркер-режим: ПараметрЗапуска <> "" → форма не открывается, серверный метод
//     ВыполнитьВоркерСервер выполняется и приложение завершается.

#Область ПрограммныйИнтерфейс

// Точка входа воркер-режима. Вызывается из ВыполнитьВоркер модуля формы.
// Разбирает строку команды и вызывает соответствующий приватный метод.
//
// Формат строки: "<СценарийКод>:<арг1>[:<арг2>:<арг3>...]"
// Примеры:
//   TLOCK_HOLDER:AccumulationRegister.ОплатаСчетов:15:1
//   TLOCK_WAITER:AccumulationRegister.ОплатаСчетов:20:1
//   DEADLOCK_ESC_A:AccumulationRegister.ОплатаСчетов:5
//   DEADLOCK_ORDER_A:AccumulationRegister.A,AccumulationRegister.B:3
//
Функция ВыполнитьВоркерСервер(СтрокаПараметра) Экспорт

	Части = СтрРазделить(СтрокаПараметра, ":", Ложь);
	Если Части.Количество() < 2 Тогда
		Возврат "ОШИБКА: некорректный формат параметра. Ожидается СценарийКод:арг1[:арг2]";
	КонецЕсли;

	СценарийКод = Части[0];
	Аргумент1 = Части[1];
	Аргумент2 = ?(Части.Количество() > 2, Части[2], "");

	Попытка
		Если СценарийКод = "TLOCK_HOLDER" Тогда
			Возврат _ВоркерTLOCKHolder(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "TLOCK_WAITER" Тогда
			Возврат _ВоркерTLOCKWaiter(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "DEADLOCK_ESC_A" Или СценарийКод = "DEADLOCK_ESC_B" Тогда
			Возврат _ВоркерDeadlockЭскалация(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "DEADLOCK_ORDER_A" Или СценарийКод = "DEADLOCK_ORDER_B" Тогда
			Возврат _ВоркерDeadlockРазныйПорядок(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "DEADLOCK_RES_A" Или СценарийКод = "DEADLOCK_RES_B" Тогда
			Возврат _ВоркерDeadlockОдинРесурс(Аргумент1, Число(Аргумент2));
		// Sprint 9 — новые сценарии
		ИначеЕсли СценарийКод = "DEADLOCK_XX_A" Или СценарийКод = "DEADLOCK_XX_B" Тогда
			Возврат _ВоркерDeadlockXX(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "DEADLOCK_CHAIN_A" Или СценарийКод = "DEADLOCK_CHAIN_B"
			Или СценарийКод = "DEADLOCK_CHAIN_C" Тогда
			Возврат _ВоркерDeadlockЦепочка(Аргумент1, Число(Аргумент2));
		ИначеЕсли СценарийКод = "LONG_TXN" Тогда
			Возврат _ВоркерLongTransaction(Аргумент1, Число(Аргумент2));
		Иначе
			Возврат "ОШИБКА: неизвестный сценарий " + СценарийКод;
		КонецЕсли;
	Исключение
		// Дедлок и таймаут блокировки выбрасывают исключение — это ожидаемо
		// и записывается в ТЖ как TDEADLOCK/TLOCK событие.
		Возврат "Исключение (нормально для блокировок): " + ОписаниеОшибки();
	КонецПопытки;

КонецФункции

// Запуск воркера через ФоновыеЗадания. Требует установленного расширения
// ТЖМоделированиеРасш с общим модулем ВоркерыТЖ.
//
// СценарийКод: "HOLDER", "WAITER", "DEADLOCK_ESC", "DEADLOCK_ORDER", "DEADLOCK_RES"
// МассивПараметров: массив аргументов для метода воркера
//
// Возвращает строку с UUID задания при успехе или начинающуюся с "ОШИБКА:" при неудаче.
// Клиент по префиксу решает делать ли fallback на WScript.Shell.
Функция ЗапуститьВоркерЧерезФЗ(СценарийКод, МассивПараметров) Экспорт

	// Сопоставление кода сценария с методом расширения
	ИмяМетода = "";
	Если СценарийКод = "HOLDER" Тогда
		ИмяМетода = "ВоркерыТЖ.БлокировкаHolder";
	ИначеЕсли СценарийКод = "WAITER" Тогда
		ИмяМетода = "ВоркерыТЖ.БлокировкаWaiter";
	ИначеЕсли СценарийКод = "DEADLOCK_ESC" Тогда
		ИмяМетода = "ВоркерыТЖ.ДедлокЭскалация";
	ИначеЕсли СценарийКод = "DEADLOCK_ORDER" Тогда
		ИмяМетода = "ВоркерыТЖ.ДедлокРазныйПорядок";
	ИначеЕсли СценарийКод = "DEADLOCK_RES" Тогда
		ИмяМетода = "ВоркерыТЖ.ДедлокОдинРесурс";
	// Sprint 9 — новые сценарии
	ИначеЕсли СценарийКод = "DEADLOCK_XX" Тогда
		ИмяМетода = "ВоркерыТЖ.ДедлокXX";
	ИначеЕсли СценарийКод = "DEADLOCK_CHAIN" Тогда
		ИмяМетода = "ВоркерыТЖ.ДедлокЦепочка";
	ИначеЕсли СценарийКод = "LONG_TXN" Тогда
		ИмяМетода = "ВоркерыТЖ.ДлиннаяТранзакция";
	Иначе
		Возврат "ОШИБКА: неизвестный СценарийКод " + СценарийКод;
	КонецЕсли;

	Попытка
		Задание = ФоновыеЗадания.Выполнить(ИмяМетода, МассивПараметров, , "ТЖ " + СценарийКод);
		Возврат "OK:" + Строка(Задание.УникальныйИдентификатор);
	Исключение
		// Расширение не установлено или метод не найден
		Возврат "ОШИБКА: " + ОписаниеОшибки();
	КонецПопытки;

КонецФункции

// Серверная пауза в секундах. Используется в основной сессии для оркестрации сценариев.
// Реализована через WScript.Shell ping чтобы не съедать CPU.
Процедура СерверПаузаСекунд(Секунд) Экспорт

	Если Секунд <= 0 Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Шелл = Новый COMОбъект("WScript.Shell");
		// ping -n N делает N-1 ответов с интервалом 1 секунда.
		Шелл.Run("cmd /c ping -n " + Формат(Секунд + 1, "ЧГ=") + " 127.0.0.1 >nul", 0, Истина);
	Исключение
		// Fallback: занятый цикл (съедает CPU, но работает).
		Финиш = ТекущаяДатаСеанса() + Секунд;
		Пока ТекущаяДатаСеанса() < Финиш Цикл
			// busy wait
		КонецЦикла;
	КонецПопытки;

КонецПроцедуры

// Сценарий 5 — медленные SQL-запросы для генерации DBMSSQL событий.
// Выполняется в текущей сессии последовательно.
Функция ВыполнитьМедленныеЗапросы(КоличествоЗапросов, ПорогМс) Экспорт

	ВыполненоУспешно = 0;
	ОшибокЗапросов = 0;

	Для НомерЗапроса = 1 По КоличествоЗапросов Цикл

		ТекстЗапроса = ПолучитьМедленныйЗапрос(НомерЗапроса, ПорогМс);

		Попытка
			Запрос = Новый Запрос(ТекстЗапроса);
			Запрос.Выполнить();
			ВыполненоУспешно = ВыполненоУспешно + 1;
		Исключение
			// Запросы по пустым таблицам могут вернуть ошибку — игнорируем,
			// нам важно что запрос ушёл в СУБД и записался в ТЖ.
			ОшибокЗапросов = ОшибокЗапросов + 1;
		КонецПопытки;

	КонецЦикла;

	Возврат "Выполнено " + ВыполненоУспешно + ", с ошибками (норма для пустых таблиц): " + ОшибокЗапросов;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// TLOCK Holder — берёт исключительную блокировку и держит её ВремяСек секунд.
// Транзакция откатывается, в базе ничего не меняется.
Функция _ВоркерTLOCKHolder(ИмяРегистра, ВремяСек)

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		// Удерживаем блокировку.
		СерверПаузаСекунд(ВремяСек);

		ОтменитьТранзакцию();
		Возврат "HOLDER: успех, удерживал " + ВремяСек + " сек";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// TLOCK Waiter — пытается получить ту же блокировку. Ждёт пока Holder не отпустит.
// Если ожидание > порога в logcfg.xml (1 сек) — платформа запишет TLOCK event.
Функция _ВоркерTLOCKWaiter(ИмяРегистра, ВремяОжиданияСек)

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		// Сразу отпускаем — нам не нужно держать.
		ОтменитьТранзакцию();
		Возврат "WAITER: блокировка получена после ожидания";
	Исключение
		ОтменитьТранзакцию();
		// Это нормальный исход — Waiter мог получить таймаут.
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Дедлок типа 1 — эскалация блокировки в одной транзакции (S → X).
// Два воркера сначала берут S на один ресурс, потом оба пытаются повысить до X.
Функция _ВоркерDeadlockЭскалация(ИмяРегистра, ПаузаСек)

	НачатьТранзакцию();
	Попытка
		// Шаг 1: разделяемая блокировка
		Блокировка1 = Новый БлокировкаДанных;
		Эл1 = Блокировка1.Добавить(ИмяРегистра);
		Эл1.Режим = РежимБлокировкиДанных.Разделяемый;
		Блокировка1.Заблокировать();

		// Пауза чтобы второй воркер тоже успел взять S
		СерверПаузаСекунд(ПаузаСек);

		// Шаг 2: пытаемся повысить до X — здесь происходит дедлок
		Блокировка2 = Новый БлокировкаДанных;
		Эл2 = Блокировка2.Добавить(ИмяРегистра);
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка2.Заблокировать();

		ОтменитьТранзакцию();
		Возврат "DEADLOCK_ESC: оба этапа прошли (дедлок не случился — повтори)";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Дедлок типа 2 — захват ресурсов в разном порядке.
// Воркер A: рег1 → рег2; воркер B: рег2 → рег1.
// Аргумент1: "Рег1,Рег2" — порядок захвата.
Функция _ВоркерDeadlockРазныйПорядок(ПараРегистров, ПаузаСек)

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		Возврат "ОШИБКА: ожидается пара регистров через запятую";
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		// Захватываем первый ресурс (X)
		Блок1 = Новый БлокировкаДанных;
		Эл1 = Блок1.Добавить(СокрЛП(Регистры[0]));
		Эл1.Режим = РежимБлокировкиДанных.Исключительный;
		Блок1.Заблокировать();

		// Пауза чтобы второй воркер захватил свой первый ресурс
		СерверПаузаСекунд(ПаузаСек);

		// Захватываем второй ресурс — здесь дедлок если второй воркер ждёт нашего
		Блок2 = Новый БлокировкаДанных;
		Эл2 = Блок2.Добавить(СокрЛП(Регистры[1]));
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блок2.Заблокировать();

		ОтменитьТранзакцию();
		Возврат "DEADLOCK_ORDER: оба регистра захвачены";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Дедлок типа 3 — конкуренция за один ресурс через X-блокировки
// после взятия S на другом регистре. Оба воркера хотят X на основном.
Функция _ВоркерDeadlockОдинРесурс(ПараРегистров, ПаузаСек)

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		Возврат "ОШИБКА: ожидается пара регистров через запятую (основной, вспомогательный)";
	КонецЕсли;

	ОсновнойРегистр = СокрЛП(Регистры[0]);
	ВспомогРегистр = СокрЛП(Регистры[1]);

	НачатьТранзакцию();
	Попытка
		// Шаг 1: S на вспомогательном
		БлокS = Новый БлокировкаДанных;
		ЭлS = БлокS.Добавить(ВспомогРегистр);
		ЭлS.Режим = РежимБлокировкиДанных.Разделяемый;
		БлокS.Заблокировать();

		// Пауза для синхронизации с другим воркером
		СерверПаузаСекунд(ПаузаСек);

		// Шаг 2: X на основном — оба воркера конкурируют
		БлокX = Новый БлокировкаДанных;
		ЭлX = БлокX.Добавить(ОсновнойРегистр);
		ЭлX.Режим = РежимБлокировкиДанных.Исключительный;
		БлокX.Заблокировать();

		ОтменитьТранзакцию();
		Возврат "DEADLOCK_RES: X получен";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Sprint 9 — Сценарий 9: тяжёлые агрегационные запросы (нагрузка на память).
// Запросы с UNION ALL и большим GROUP BY — ожидаемый Memory Grant в плане.
// Выполняется в текущей сессии, транзакции нет.
Функция ВыполнитьТяжёлыеЗапросы() Экспорт

	Выполнено = 0;
	Ошибок = 0;
	ТяжёлыеЗапросы = _ПолучитьТяжёлыеЗапросы();

	Для Каждого Текст Из ТяжёлыеЗапросы Цикл
		Попытка
			Запрос = Новый Запрос(Текст);
			Запрос.Выполнить();
			Выполнено = Выполнено + 1;
		Исключение
			Ошибок = Ошибок + 1;
		КонецПопытки;
	КонецЦикла;

	Возврат "Выполнено " + Выполнено + " тяжёлых запросов, ошибок (норма): " + Ошибок;

КонецФункции

// Sprint 9 — Сценарий 10: N+1 каскад.
// Основной запрос получает N записей, затем по каждой записи выполняется подзапрос-деталь.
// В ТЖ видно как серия коротких DBMSSQL событий — типичная N+1 проблема.
Функция ВыполнитьN1Каскад(Количество) Экспорт

	Ошибок = 0;
	ВыполненоОсновных = 0;
	ВыполненоДеталей = 0;

	// Шаг 1: "Основной" запрос — имитируем получение списка объектов
	Для НомерОсновного = 1 По 3 Цикл
		ТекстОсновного = "ВЫБРАТЬ ПЕРВЫЕ " + Количество + "
						|	Т.Организация КАК Организация,
						|	СУММА(Т.Сумма) КАК ИтогоСумма
						|ИЗ
						|	РегистрНакопления.ОплатаСчетов КАК Т
						|СГРУППИРОВАТЬ ПО
						|	Т.Организация";
		Попытка
			Запрос = Новый Запрос(ТекстОсновного);
			Выборка = Запрос.Выполнить().Выгрузить();
			ВыполненоОсновных = ВыполненоОсновных + 1;

			// Шаг 2: Для каждой строки — "детальный" подзапрос (имитируем N+1)
			Для Каждого Строка Из Выборка Цикл
				ТекстДетали = "ВЫБРАТЬ
								|	Т.Период,
								|	Т.Регистратор,
								|	Т.Сумма
								|ИЗ
								|	РегистрНакопления.ОплатаСчетов КАК Т
								|ГДЕ
								|	Т.Организация = &Орг
								|УПОРЯДОЧИТЬ ПО Т.Период УБЫВ";
				Попытка
					ЗапросД = Новый Запрос(ТекстДетали);
					ЗапросД.УстановитьПараметр("Орг", Строка.Организация);
					ЗапросД.Выполнить();
					ВыполненоДеталей = ВыполненоДеталей + 1;
				Исключение
					Ошибок = Ошибок + 1;
				КонецПопытки;
			КонецЦикла;
		Исключение
			Ошибок = Ошибок + 1;
		КонецПопытки;
	КонецЦикла;

	Возврат "Основных: " + ВыполненоОсновных + ", деталей: " + ВыполненоДеталей + ", ошибок: " + Ошибок;

КонецФункции

// Sprint 9 — Сценарий 12: PG-паттерны.
// Запросы с SELECT *, LIKE '%...%', NOT IN с подзапросом.
// Эти паттерны детектируются движком PG-антипаттернов Optimyzer после импорта ТЖ.
Функция ВыполнитьPGПаттерны() Экспорт

	Выполнено = 0;
	Ошибок = 0;

	// Паттерн 1: SELECT * (антипаттерн select_star)
	Попытка
		Запрос1 = Новый Запрос("ВЫБРАТЬ * ИЗ РегистрНакопления.ОплатаСчетов");
		Запрос1.Выполнить();
		Выполнено = Выполнено + 1;
	Исключение
		Ошибок = Ошибок + 1;
	КонецПопытки;

	// Паттерн 2: LIKE с ведущим % (антипаттерн like_with_leading_wildcard)
	Попытка
		Запрос2 = Новый Запрос("ВЫБРАТЬ Т.Организация ИЗ РегистрНакопления.ОплатаСчетов КАК Т
								|ГДЕ Т.Организация.Наименование ПОДОБНО ""%ООО%""");
		Запрос2.Выполнить();
		Выполнено = Выполнено + 1;
	Исключение
		Ошибок = Ошибок + 1;
	КонецПопытки;

	// Паттерн 3: NOT IN с подзапросом (антипаттерн not_in_with_subquery)
	Попытка
		Запрос3 = Новый Запрос("ВЫБРАТЬ Т.Организация
								|ИЗ РегистрНакопления.ОплатаСчетов КАК Т
								|ГДЕ Т.Регистратор НЕ В
								|	(ВЫБРАТЬ В.Ссылка ИЗ Документ.СчётНаОплатуПокупателю КАК В)");
		Запрос3.Выполнить();
		Выполнено = Выполнено + 1;
	Исключение
		Ошибок = Ошибок + 1;
	КонецПопытки;

	// Паттерн 4: Декартово соединение без условия ON (антипаттерн cross_join / missing_join_predicate)
	Попытка
		Запрос4 = Новый Запрос("ВЫБРАТЬ Т1.Организация, Т2.Организация КАК Орг2
								|ИЗ РегистрНакопления.ОплатаСчетов КАК Т1,
								|	РегистрНакопления.НачисленияУдержанияПоСотрудникам КАК Т2");
		Запрос4.Выполнить();
		Выполнено = Выполнено + 1;
	Исключение
		Ошибок = Ошибок + 1;
	КонецПопытки;

	Возврат "PG-паттерны: " + Выполнено + " запросов выполнено, ошибок: " + Ошибок;

КонецФункции

// Возвращает текст медленного запроса. Каждый запрос имеет разную природу,
// что даст разные паттерны в DBMSSQL анализе:
//   - full table scan
//   - подзапрос в условии
//   - группировка с большим количеством полей
//   - неэффективное соединение
//   - сортировка по выражению
//
// Запросы намеренно неэффективны. Они работают по типовым таблицам БП 3.0
// (регистр накопления ОплатаСчетов) и должны на реальных данных давать
// длительность > порога в logcfg.xml (>100 мс) и попадать в ТЖ как DBMSSQL события.
Функция ПолучитьМедленныйЗапрос(НомерЗапроса, ПорогМс)

	ВариантЗапроса = (НомерЗапроса - 1) % 5;

	Если ВариантЗапроса = 0 Тогда
		// Full table scan — выборка всех записей регистра без отбора
		Возврат "ВЫБРАТЬ
				|	Т.*
				|ИЗ
				|	РегистрНакопления.ОплатаСчетов КАК Т";

	ИначеЕсли ВариантЗапроса = 1 Тогда
		// Подзапрос в условии (антипаттерн)
		Возврат "ВЫБРАТЬ
				|	Т.Период,
				|	Т.Сумма
				|ИЗ
				|	РегистрНакопления.ОплатаСчетов КАК Т
				|ГДЕ
				|	Т.Сумма В
				|		(ВЫБРАТЬ
				|			В.Сумма
				|		ИЗ
				|			РегистрНакопления.ОплатаСчетов КАК В)";

	ИначеЕсли ВариантЗапроса = 2 Тогда
		// Группировка по большому набору полей
		Возврат "ВЫБРАТЬ
				|	Т.Период,
				|	Т.Регистратор,
				|	Т.НомерСтроки,
				|	Т.Организация,
				|	СУММА(Т.Сумма) КАК Сумма,
				|	СУММА(Т.СуммаНДС) КАК СуммаНДС
				|ИЗ
				|	РегистрНакопления.ОплатаСчетов КАК Т
				|СГРУППИРОВАТЬ ПО
				|	Т.Период,
				|	Т.Регистратор,
				|	Т.НомерСтроки,
				|	Т.Организация";

	ИначеЕсли ВариантЗапроса = 3 Тогда
		// Неэффективное соединение двух больших регистров
		Возврат "ВЫБРАТЬ
				|	Т1.Период КАК Период,
				|	Т1.Организация КАК Организация,
				|	КОЛИЧЕСТВО(Т2.Регистратор) КАК Количество
				|ИЗ
				|	РегистрНакопления.ОплатаСчетов КАК Т1
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НачисленияУдержанияПоСотрудникам КАК Т2
				|		ПО Т1.Период = Т2.Период
				|СГРУППИРОВАТЬ ПО
				|	Т1.Период,
				|	Т1.Организация";

	Иначе
		// Сортировка по выражению — нельзя использовать индекс
		Возврат "ВЫБРАТЬ ПЕРВЫЕ 1000
				|	Т.Период,
				|	Т.Сумма
				|ИЗ
				|	РегистрНакопления.ОплатаСчетов КАК Т
				|УПОРЯДОЧИТЬ ПО
				|	ВЫРАЗИТЬ(Т.Сумма КАК ЧИСЛО(15, 2)) * 2 УБЫВ,
				|	Т.Период УБЫВ";
	КонецЕсли;

КонецФункции

// Sprint 9 — Возвращает список тяжёлых агрегационных запросов для сценария Memory.
// Запросы с ИТОГИ, UNION ALL, РАЗЛИЧНЫЕ — создают давление на tempdb/sort buffer.
Функция _ПолучитьТяжёлыеЗапросы()

	Список = Новый Массив;

	// Запрос 1: ИТОГИ по нескольким уровням (вложенные агрегаты)
	Список.Добавить("ВЫБРАТЬ
					|	Т.Период КАК Период,
					|	Т.Организация КАК Организация,
					|	Т.Регистратор КАК Регистратор,
					|	СУММА(Т.Сумма) КАК Сумма,
					|	СУММА(Т.СуммаНДС) КАК СуммаНДС
					|ИЗ
					|	РегистрНакопления.ОплатаСчетов КАК Т
					|СГРУППИРОВАТЬ ПО
					|	Т.Период, Т.Организация, Т.Регистратор
					|ИТОГИ
					|	СУММА(Сумма), СУММА(СуммаНДС)
					|ПО
					|	Период ПЕРИОДАМИ(МЕСЯЦ, НАЧАЛОПЕРИОДА(&НачПериода, ГОД), КОНЕЦПЕРИОДА(&НачПериода, ГОД)),
					|	Организация");

	// Запрос 2: UNION ALL трёх регистров (широкий результирующий набор)
	Список.Добавить("ВЫБРАТЬ
					|	""ОплатаСчетов"" КАК Источник,
					|	Т.Период,
					|	Т.Организация,
					|	Т.Сумма КАК Сумма
					|ИЗ
					|	РегистрНакопления.ОплатаСчетов КАК Т
					|ОБЪЕДИНИТЬ ВСЕ
					|ВЫБРАТЬ
					|	""НачисленияПоСотрудникам"" КАК Источник,
					|	Т.Период,
					|	Т.Сотрудник.Организация,
					|	Т.Сумма КАК Сумма
					|ИЗ
					|	РегистрНакопления.НачисленияУдержанияПоСотрудникам КАК Т
					|ОБЪЕДИНИТЬ ВСЕ
					|ВЫБРАТЬ
					|	""ОценочныеОбязательства"" КАК Источник,
					|	Т.Период,
					|	Т.Организация,
					|	Т.Сумма КАК Сумма
					|ИЗ
					|	РегистрНакопления.ОценочныеОбязательства КАК Т");

	// Запрос 3: РАЗЛИЧНЫЕ на большой выборке (требует sort+deduplicate)
	Список.Добавить("ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	Т.Организация,
					|	Т.Регистратор.Дата КАК ДатаДок,
					|	Т.НомерСтроки
					|ИЗ
					|	РегистрНакопления.ОплатаСчетов КАК Т
					|УПОРЯДОЧИТЬ ПО
					|	ДатаДок УБЫВ,
					|	Т.Организация");

	// Параметр для первого запроса
	Запрос = Новый Запрос(Список[0]);
	Запрос.УстановитьПараметр("НачПериода", НачалоГода(ТекущаяДатаСеанса()));
	Список[0] = Запрос.Текст;
	// Убираем параметр чтобы не смешивать — вернём прямой текст
	Список[0] = СтрЗаменить(Список[0], "&НачПериода", """01.01.2024""");

	Возврат Список;

КонецФункции

// Sprint 9 — Воркер TDEADLOCK X-X.
// Явный X-X дедлок: оба воркера используют Исключительный режим.
// Аргумент1: "РегА,РегБ" — регистры в порядке захвата (у второго воркера порядок обратный).
Функция _ВоркерDeadlockXX(ПараРегистров, ПаузаСек)

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		Возврат "ОШИБКА: ожидается пара регистров через запятую";
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		// X на первом регистре
		Блок1 = Новый БлокировкаДанных;
		Эл1 = Блок1.Добавить(СокрЛП(Регистры[0]));
		Эл1.Режим = РежимБлокировкиДанных.Исключительный;
		Блок1.Заблокировать();

		// Пауза — даём второму воркеру захватить его первый ресурс
		СерверПаузаСекунд(ПаузаСек);

		// X на втором регистре — здесь дедлок если второй воркер уже захватил его
		Блок2 = Новый БлокировкаДанных;
		Эл2 = Блок2.Добавить(СокрЛП(Регистры[1]));
		Эл2.Режим = РежимБлокировкиДанных.Исключительный;
		Блок2.Заблокировать();

		ОтменитьТранзакцию();
		Возврат "DEADLOCK_XX: X получен на оба регистра";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Sprint 9 — Воркер цепочки дедлока.
// Участвует в 3-сторонней цепочке: A->B->C->A.
// Аргумент1: "РегОт,РегДо" — захватывает X(РегОт), ждёт, пытается X(РегДо).
Функция _ВоркерDeadlockЦепочка(ПараРегистров, ПаузаСек)

	Регистры = СтрРазделить(ПараРегистров, ",", Ложь);
	Если Регистры.Количество() <> 2 Тогда
		Возврат "ОШИБКА: ожидается пара регистров через запятую";
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		// Шаг 1: берём X на "своём" регистре
		БлокОт = Новый БлокировкаДанных;
		ЭлОт = БлокОт.Добавить(СокрЛП(Регистры[0]));
		ЭлОт.Режим = РежимБлокировкиДанных.Исключительный;
		БлокОт.Заблокировать();

		// Пауза — даём следующему в цепочке захватить его ресурс
		СерверПаузаСекунд(ПаузаСек);

		// Шаг 2: пытаемся взять X на "следующем" регистре — возможен дедлок
		БлокДо = Новый БлокировкаДанных;
		ЭлДо = БлокДо.Добавить(СокрЛП(Регистры[1]));
		ЭлДо.Режим = РежимБлокировкиДанных.Исключительный;
		БлокДо.Заблокировать();

		ОтменитьТранзакцию();
		Возврат "DEADLOCK_CHAIN: оба ресурса получены";
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

// Sprint 9 — Сценарий 13: длинная транзакция.
// Держит X-блокировку ВремяСек секунд без каких-либо изменений в БД.
// Полезно для проверки мониторинга длинных транзакций.
Функция _ВоркерLongTransaction(ИмяРегистра, ВремяСек)

	Если ВремяСек < 5 Тогда
		ВремяСек = 30; // Минимум 30 сек для значимого события
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлБлок = Блокировка.Добавить(ИмяРегистра);
		ЭлБлок.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();

		// Держим блокировку долго — это имитирует "забытую" долгую транзакцию
		СерверПаузаСекунд(ВремяСек);

		ОтменитьТранзакцию();
		Возврат "LONG_TXN: X удерживался " + ВремяСек + " сек на " + ИмяРегистра;
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецФункции

#КонецОбласти
