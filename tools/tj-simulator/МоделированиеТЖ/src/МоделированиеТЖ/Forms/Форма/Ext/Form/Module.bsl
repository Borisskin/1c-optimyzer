#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Дефолтные настройки. Сергей корректирует под свою базу при необходимости.
	ПараметрыПодключения = "Srvr=""localhost:2541"";Ref=""Test1CProf""";
	ПользовательИБ = "BVS";
	ПарольИБ = "";
	ПутьКПлатформе = "C:\Program Files\1cv8\8.3.27.1859\bin\1cv8c.exe";

	// Три регистра типовой БП 3.0 с DataLockControlMode = Managed.
	Регистр1 = "AccumulationRegister.ОплатаСчетов";
	Регистр2 = "AccumulationRegister.НачисленияУдержанияПоСотрудникам";
	Регистр3 = "AccumulationRegister.ОценочныеОбязательства";

	КоличествоTLOCK = 10;
	КоличествоDEADLOCK = 5;
	КоличествоЗапросов = 20;
	ПорогДлительностиЗапросаМс = 200;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	// Воркер-режим: обработка запущена с параметром /C"WORKER:<сценарий>:..." через 1cv8c.exe.
	// НЕ ставим Отказ=Истина — это инициирует закрытие приложения с дёрганьем сервера БСП.
	// Откладываем выполнение через ПодключитьОбработчикОжидания.
	Если ПараметрЗапуска <> "" Тогда
		ПодключитьОбработчикОжидания("ВыполнитьВоркерОтложенно", 0.1, Истина);
		Возврат;
	КонецЕсли;

	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "ВНИМАНИЕ: запускайте только на тестовой базе. Все транзакции откатываются.";
	Сообщение.Сообщить();

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьВоркерОтложенно()

	// Вызывается через 0.1 сек после ПриОткрытии в воркер-режиме.
	Попытка
		Результат = ВыполнитьВоркерСерверНаСервере(ПараметрЗапуска);
		ЛогироватьВоркер(ПараметрЗапуска, Результат);
	Исключение
		ЛогироватьВоркер(ПараметрЗапуска, "ОШИБКА: " + ОписаниеОшибки());
	КонецПопытки;

	// Воркер отработал — приложение больше не нужно. Закрываем без подтверждения.
	Попытка
		ПрекратитьРаботуСистемы(Ложь);
	Исключение
		// На случай если метод недоступен
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СценарийTLOCKКоманда(Команда)

	ДобавитьВИсторию("Сценарий 1: TLOCK", "Запуск", "Стартует " + Формат(КоличествоTLOCK, "ЧГ=") + " пар воркеров");

	Для Итерация = 1 По КоличествоTLOCK Цикл
		ВыполнитьПаруВоркеровTLOCK(Регистр1, Итерация);
	КонецЦикла;

	ДобавитьВИсторию("Сценарий 1: TLOCK", "Завершён", "Ждите ~15 сек на каждый цикл, проверяйте ТЖ");

КонецПроцедуры

&НаКлиенте
Процедура СценарийDeadlockЭскалацияКоманда(Команда)

	ДобавитьВИсторию("Сценарий 2: Дедлок эскалация", "Запуск", Формат(КоличествоDEADLOCK, "ЧГ=") + " итераций S->X на " + Регистр1);

	Для Итерация = 1 По КоличествоDEADLOCK Цикл
		ВыполнитьПаруВоркеровDeadlock(
			"DEADLOCK_ESC",
			СоздатьМассив(Регистр1, 5),
			"DEADLOCK_ESC_A:" + Регистр1 + ":5:" + Итерация,
			"DEADLOCK_ESC_B:" + Регистр1 + ":5:" + Итерация,
			"Дедлок-эск #" + Итерация);
		// Пауза между итерациями: 10 сек = пауза 5 сек на дедлок + 3 сек на старт +
		// запас 2 сек, чтобы предыдущая пара завершилась до старта следующей.
		Если Итерация < КоличествоDEADLOCK Тогда
			СерверПаузаСекундНаСервере(10);
		КонецЕсли;
	КонецЦикла;

	ДобавитьВИсторию("Сценарий 2: Дедлок эскалация", "Завершён", "ожидайте до 30 сек на разруливание последнего");

КонецПроцедуры

&НаКлиенте
Процедура СценарийDeadlockРазныйПорядокКоманда(Команда)

	ДобавитьВИсторию("Сценарий 3: Разный порядок", "Запуск", Формат(КоличествоDEADLOCK, "ЧГ=") + " итераций; " + Регистр1 + " <-> " + Регистр2);

	Для Итерация = 1 По КоличествоDEADLOCK Цикл
		ВыполнитьПаруВоркеровDeadlock(
			"DEADLOCK_ORDER",
			Неопределено,
			"DEADLOCK_ORDER_A:" + Регистр1 + "," + Регистр2 + ":5:" + Итерация,
			"DEADLOCK_ORDER_B:" + Регистр2 + "," + Регистр1 + ":5:" + Итерация,
			"Дедлок-пор #" + Итерация);
		Если Итерация < КоличествоDEADLOCK Тогда
			СерверПаузаСекундНаСервере(10);
		КонецЕсли;
	КонецЦикла;

	ДобавитьВИсторию("Сценарий 3: Разный порядок", "Завершён", "A: рег1->рег2; B: рег2->рег1");

КонецПроцедуры

&НаКлиенте
Процедура СценарийDeadlockОдинРесурсКоманда(Команда)

	ДобавитьВИсторию("Сценарий 4: Один ресурс", "Запуск", Формат(КоличествоDEADLOCK, "ЧГ=") + " итераций X-X на " + Регистр3);

	Для Итерация = 1 По КоличествоDEADLOCK Цикл
		ВыполнитьПаруВоркеровDeadlock(
			"DEADLOCK_RES",
			Неопределено,
			"DEADLOCK_RES_A:" + Регистр3 + "," + Регистр1 + ":5:" + Итерация,
			"DEADLOCK_RES_B:" + Регистр3 + "," + Регистр1 + ":5:" + Итерация,
			"Дедлок-рес #" + Итерация);
		Если Итерация < КоличествоDEADLOCK Тогда
			СерверПаузаСекундНаСервере(10);
		КонецЕсли;
	КонецЦикла;

	ДобавитьВИсторию("Сценарий 4: Один ресурс", "Завершён", "Оба хотят X на регистре 3");

КонецПроцедуры

&НаКлиенте
Процедура СценарийDBMSSQLКоманда(Команда)

	ДобавитьВИсторию("Сценарий 5: DBMSSQL", "Запуск", Формат(КоличествоЗапросов, "ЧГ=") + " медленных запросов");

	Результат = ВыполнитьМедленныеЗапросыНаСервере(КоличествоЗапросов, ПорогДлительностиЗапросаМс);

	ДобавитьВИсторию("Сценарий 5: DBMSSQL", "Завершён", Результат);

КонецПроцедуры

&НаКлиенте
Процедура СценарийВсеКоманда(Команда)

	ДобавитьВИсторию("Сценарий 6: Всё подряд", "Запуск", "Запуск всех 5 сценариев с паузами");

	СценарийTLOCKКоманда(Команда);
	СерверПаузаСекундНаСервере(3);

	СценарийDeadlockЭскалацияКоманда(Команда);
	СерверПаузаСекундНаСервере(20);

	СценарийDeadlockРазныйПорядокКоманда(Команда);
	СерверПаузаСекундНаСервере(20);

	СценарийDeadlockОдинРесурсКоманда(Команда);
	СерверПаузаСекундНаСервере(20);

	СценарийDBMSSQLКоманда(Команда);

	ДобавитьВИсторию("Сценарий 6: Всё подряд", "Завершён", "Все 5 сценариев отработали");

КонецПроцедуры

#КонецОбласти

#Область СерверныеОбёртки

// В управляемой форме реквизит "Объект" — это ДанныеФормыСтруктура и на клиенте, и на сервере.
// Чтобы получить полноценный экземпляр объекта обработки с доступом к методам модуля объекта,
// используется РеквизитФормыВЗначение("Объект"). Парный метод ЗначениеВРеквизитФормы() возвращает
// изменения обратно (нам это не нужно — методы только читают/выполняют, ничего не меняют в Объекте).

&НаСервере
Функция ЗапуститьВоркерЧерезФЗНаСервере(СценарийКод, МассивПараметров)
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	Возврат ОбъектОбработки.ЗапуститьВоркерЧерезФЗ(СценарийКод, МассивПараметров);
КонецФункции

&НаСервере
Процедура СерверПаузаСекундНаСервере(Секунд)
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	ОбъектОбработки.СерверПаузаСекунд(Секунд);
КонецПроцедуры

&НаСервере
Функция ВыполнитьМедленныеЗапросыНаСервере(КоличествоЗапросов, ПорогМс)
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	Возврат ОбъектОбработки.ВыполнитьМедленныеЗапросы(КоличествоЗапросов, ПорогМс);
КонецФункции

&НаСервере
Функция ВыполнитьВоркерСерверНаСервере(Параметр)
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	Возврат ОбъектОбработки.ВыполнитьВоркерСервер(Параметр);
КонецФункции

&НаСервере
Функция ПолучитьПутьКОбработкеНаСервере()
	// Свойство ИспользуемоеИмяФайла читается только у полноценного объекта обработки.
	Возврат РеквизитФормыВЗначение("Объект").ИспользуемоеИмяФайла;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ДобавитьВИсторию(Сценарий, Статус, Результат)

	НоваяСтрока = ИсторияЗапусков.Добавить();
	НоваяСтрока.Время = ТекущаяДата();
	НоваяСтрока.Сценарий = Сценарий;
	НоваяСтрока.Статус = Статус;
	НоваяСтрока.Результат = Результат;

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПаруВоркеровTLOCK(ИмяРегистра, НомерЦикла)

	// Воркер A: держит исключительную блокировку 5 сек.
	// Воркер B: пытается получить ту же блокировку через 2 сек -> ждёт ~3 сек -> пишет TLOCK в ТЖ.
	// 5 сек удержания > 1 сек порога logcfg → событие гарантированно попадает в журнал.
	ЗапуститьВоркер("HOLDER", СоздатьМассив(ИмяРегистра, 5), "TLOCK_HOLDER:" + ИмяРегистра + ":5:" + НомерЦикла, "TLOCK Holder #" + НомерЦикла);

	// Пауза 2 сек — даём 1cv8c.exe время запуститься и Holder'у захватить блокировку.
	СерверПаузаСекундНаСервере(2);

	ЗапуститьВоркер("WAITER", СоздатьМассив(ИмяРегистра), "TLOCK_WAITER:" + ИмяРегистра + ":20:" + НомерЦикла, "TLOCK Waiter #" + НомерЦикла);

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПаруВоркеровDeadlock(СценарийКод, МассивПараметровФЗ, ПараметрA, ПараметрB, БазоваяМетка)

	// Запуск двух конкурирующих воркеров для дедлок-сценария. Оба стартуют через
	// 1cv8c.exe /Execute практически одновременно, внутри каждого — пауза 5 сек
	// между взятием первого и второго ресурса, что даёт второму воркеру время
	// стартовать (1cv8c.exe startup ~3 сек). Платформа разруливает дедлок и
	// один из воркеров получает TDEADLOCK, второй проходит.
	ЗапуститьВоркер(СценарийКод, МассивПараметровФЗ, ПараметрA, БазоваяМетка + " A");
	ЗапуститьВоркер(СценарийКод, МассивПараметровФЗ, ПараметрB, БазоваяМетка + " B");

КонецПроцедуры

&НаКлиенте
Функция СоздатьМассив(Эл1, Эл2 = Неопределено, Эл3 = Неопределено)
	// Хелпер для создания массива через одну строку
	М = Новый Массив;
	М.Добавить(Эл1);
	Если Эл2 <> Неопределено Тогда М.Добавить(Эл2); КонецЕсли;
	Если Эл3 <> Неопределено Тогда М.Добавить(Эл3); КонецЕсли;
	Возврат М;
КонецФункции

&НаКлиенте
Процедура ЗапуститьВоркер(СценарийКод, МассивПараметровФЗ, ПараметрShellКоманды, ОписаниеВоркера)

	// КРИТИЧНО для TLOCK/TDEADLOCK: фоновые задания в одном rphost могут выполняться
	// последовательно (зависит от пула потоков кластера) — тогда Holder заканчивается
	// ДО старта Waiter, нет конкуренции блокировок, нет TLOCK/TDEADLOCK событий.
	// Поэтому всегда идём через 1cv8c.exe /Execute — это гарантирует отдельный
	// клиент-сеанс на каждый воркер и реальную параллельность транзакций.
	ЗапуститьВоркерЧерезShell(ПараметрShellКоманды, ОписаниеВоркера);

КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьВоркерЧерезShell(ПараметрКоманды, ОписаниеВоркера)

	ПутьКОбработке = ПолучитьПутьКОбработкеНаСервере();

	Если ПустаяСтрока(ПутьКОбработке) Тогда
		ДобавитьВИсторию(ОписаниеВоркера, "Ошибка", "Не определён путь к .epf — открой обработку из файла");
		Возврат;
	КонецЕсли;

	Команда = """" + ПутьКПлатформе + """"
		+ " ENTERPRISE"
		+ " /S""" + ПолучитьСерверИзСтрокиПодключения(ПараметрыПодключения) + """"
		+ ?(ПользовательИБ = "", "", " /N""" + ПользовательИБ + """")
		+ ?(ПарольИБ = "", "", " /P""" + ПарольИБ + """")
		+ " /DisableStartupMessages"
		+ " /Execute """ + ПутьКОбработке + """"
		+ " /C""" + ПараметрКоманды + """";

	Попытка
		WScript = Новый COMОбъект("WScript.Shell");
		WScript.Run(Команда, 0, Ложь);
		ДобавитьВИсторию(ОписаниеВоркера, "Запущен", "1cv8c.exe /Execute — отдельная сессия");
	Исключение
		ДобавитьВИсторию(ОписаниеВоркера, "Ошибка", "WScript.Shell недоступен: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Функция ПолучитьСерверИзСтрокиПодключения(СтрокаПодключения)

	Сервер = "";
	База = "";

	МассивКлючей = СтрРазделить(СтрокаПодключения, ";", Ложь);
	Для Каждого Ключ Из МассивКлючей Цикл
		Если СтрНачинаетсяС(ВРег(СокрЛП(Ключ)), "SRVR") Тогда
			Сервер = ИзвлечьЗначение(Ключ);
		ИначеЕсли СтрНачинаетсяС(ВРег(СокрЛП(Ключ)), "REF") Тогда
			База = ИзвлечьЗначение(Ключ);
		КонецЕсли;
	КонецЦикла;

	Возврат Сервер + "\" + База;

КонецФункции

&НаКлиенте
Функция ИзвлечьЗначение(СтрокаКлюч)

	Поз = СтрНайти(СтрокаКлюч, "=");
	Если Поз = 0 Тогда
		Возврат "";
	КонецЕсли;
	Значение = СокрЛП(Сред(СтрокаКлюч, Поз + 1));
	Если Лев(Значение, 1) = """" И Прав(Значение, 1) = """" Тогда
		Значение = Сред(Значение, 2, СтрДлина(Значение) - 2);
	КонецЕсли;
	Возврат Значение;

КонецФункции

&НаКлиенте
Процедура ЛогироватьВоркер(Параметр, Результат)

	Попытка
		ПутьЛог = КаталогВременныхФайлов() + "ТЖ_воркер_" + Формат(ТекущаяДата(), "ДФ=ггггММдд_ЧЧммсс") + "_" + Лев(СтрЗаменить(Параметр, ":", "_"), 50) + ".log";
		Запись = Новый ЗаписьТекста(ПутьЛог, КодировкаТекста.UTF8);
		Запись.ЗаписатьСтроку("Параметр: " + Параметр);
		Запись.ЗаписатьСтроку("Результат: " + Результат);
		Запись.Закрыть();
	Исключение
		// Игнорируем — лог не критичен
	КонецПопытки;

КонецПроцедуры

#КонецОбласти
