<?xml version="1.0" encoding="UTF-8"?>
<!--
  S12 / вариант A — logcfg.xml для сбора слоя СУБД в боевой ТЖ.

  Зачем: текущий C:\1C-TechLog собран без DB-слоя (нет DBMSSQL/Sql/планов/дедлоков),
  поэтому флагманские сценарии Optimyzer (медленные запросы, планы, антипаттерны)
  на нём не проверить. Этот конфиг добавляет слой СУБД + планы + блокировки + дедлоки.

  Как применить:
    1. Положить как C:\Program Files\1cv8\conf\logcfg.xml (сделай backup старого!).
       Кодировка ОБЯЗАТЕЛЬНО UTF-8 БЕЗ BOM (некоторые версии платформы не читают BOM).
    2. Перезапустить агент сервера, чтобы rphost перечитал конфиг:
         Restart-Service '1C:Enterprise 8.3 Server Agent (x86-64)' -Force
       (в файловом режиме — просто перезапустить 1С:Предприятие)
    3. Погонять боевую базу под нагрузкой 10-30 мин (провести документы, отчёты,
       закрытие месяца — то, что реально тормозит).
    4. Отдать папку C:\1C-TechLog (новые .log появятся в rphost_NNNN\).

  Проверка что планы пишутся (через ~30 сек после нагрузки):
    Get-ChildItem 'C:\1C-TechLog' -Recurse -Filter '*.log' |
      Where-Object { $_.LastWriteTime -gt (Get-Date).AddMinutes(-5) } |
      Select-String -Pattern 'planSQLText' -List | Select-Object -First 3

  КРИТИЧНО: <plansql/> стоит на уровне <config> (sibling <log>), НЕ внутри <log>.
  Если перенести внутрь <log> — платформа молча перестанет писать planSQLText.

  Порог duration value="10" = 1 мс (1С-единица = 100 мкс). Низкий порог = ловим
  почти все запросы (богатый материал для валидации). Если ТЖ пухнет — поднять
  до value="100" (10 мс) или value="1000" (100 мс): планы только для медленных.
-->
<config xmlns="http://v8.1c.ru/v8/tech-log">
    <log location="C:\1C-TechLog" history="72">

        <!-- ===== Слой СУБД (флагман: медленные запросы, Top SQL, антипаттерны) ===== -->
        <!-- MS SQL Server -->
        <event>
            <eq property="name" value="DBMSSQL"/>
            <gt property="duration" value="10"/>
        </event>
        <!-- PostgreSQL (1С пишет события БД под именем DBPOSTGRS, не DBMSSQL) -->
        <event>
            <eq property="name" value="DBPOSTGRS"/>
            <gt property="duration" value="10"/>
        </event>

        <!-- ===== Блокировки и взаимоблокировки ===== -->
        <!-- Управляемые блокировки (WaitConnections появится при реальных конфликтах) -->
        <event>
            <eq property="name" value="TLOCK"/>
        </event>
        <!-- Ожидание на блокировке (таймаут) -->
        <event>
            <eq property="name" value="TTIMEOUT"/>
        </event>
        <!-- Взаимоблокировки -->
        <event>
            <eq property="name" value="TDEADLOCK"/>
        </event>

        <!-- ===== Исключения ===== -->
        <event>
            <eq property="name" value="EXCP"/>
        </event>

        <!-- Писать все свойства событий + явно текст плана выполнения -->
        <property name="all"/>
        <property name="plansqltext"/>
    </log>

    <!-- Master-switch механизма сбора планов. ОБЯЗАН быть здесь, на уровне <config>. -->
    <plansql/>
</config>
